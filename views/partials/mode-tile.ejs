<a href="<%= basePath %>/mode/<%= mode.id %>" class="mode-tile" data-device-type="<%= mode.deviceType.toLowerCase() %>" data-mode='<%= JSON.stringify(mode) %>'>
  <div class="mode-tile-content">
      <h2 class="mode-tile-title"><%= mode.name %></h2>
  </div>
  <div class="device-preview-container">
    <svg viewBox="0 0 500 250" class="device-svg" preserveAspectRatio="xMidYMid meet">
      <image href="<%= mode.deviceType === 'Gloves' ? basePath + '/images/gloves.svg' : mode.deviceType === 'Orbit' ? basePath + '/images/orbit.svg' : mode.deviceType === 'Handle' ? basePath + '/images/handle.svg' : mode.deviceType === 'Duo' ? basePath + '/images/duo.svg' : mode.deviceType === 'Spark' ? basePath + '/images/spark.svg' : basePath + '/images/chromadeck.svg' %>" width="500" height="250"/>
      <% orderedPatternSets.forEach((pat, index) => { %>
        <circle class="led-circle" data-pat='<%= JSON.stringify(pat.data ? pat.data : pat) %>' data-type="flashing"/>
      <% }); %>
    </svg>
  </div>
  <div class="mode-tile-info-panel">
    <div class="mode-tile-info-header">
      <div class="mode-tile-info-meta">
        <% if (mode.creator) { %>
          <span class="mode-tile-info-creator"><%= mode.creator.username %></span>
        <% } %>
        <% if (mode.description) { %>
          <p class="mode-tile-info-description"><%= mode.description %></p>
        <% } %>
      </div>
      <img class="mode-tile-device-icon" src="<%= basePath + '/images/' + mode.deviceType.toLowerCase() + '-logo-square-64.png' %>" alt="<%= mode.deviceType %>">
    </div>
    <hr class="mode-tile-info-divider">
    <% let seenIds = []; %>
    <% orderedPatternSets.forEach(pat => { %>
      <% if (seenIds.includes(pat.id)) return; %>
      <% seenIds.push(pat.id); %>
      <% const data = pat.data || pat; %>
      <div class="mode-tile-info-pattern">
        <span class="mode-tile-info-pattern-name"><%= pat.name || 'Pattern' %></span>
        <div class="mode-tile-info-swatches">
          <% if (data && data.colorset) { %>
            <% data.colorset.forEach(hex => { %>
              <span class="color-swatch" style="background: <%= hex.replace('0x', '#') %>"></span>
            <% }); %>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>
</a>
