<div id="control-panel" class="control-panel expanded">
  <div class="control-panel-body">
    <div class="control-panel-section">
      <label class="control-panel-label">Speed</label>
      <input type="range" id="control-speed" class="control-speed-slider" min="0" max="50" value="20">
    </div>
    <div class="control-panel-section">
      <label class="control-panel-label">Play Mode</label>
      <div class="control-panel-toggle-group">
        <button class="control-panel-btn control-panel-play-btn active" data-mode="always">Always</button>
        <button class="control-panel-btn control-panel-play-btn" data-mode="hover">Hover</button>
      </div>
    </div>
    <div class="control-panel-section">
      <label class="control-panel-label">Preview</label>
      <div class="control-panel-toggle-group">
        <button class="control-panel-btn control-panel-preview-btn active" data-mode="device">Device</button>
        <button class="control-panel-btn control-panel-preview-btn" data-mode="info">Info</button>
      </div>
    </div>
  </div>
  <button id="control-panel-toggle" class="control-panel-toggle" aria-label="Toggle lightshow controls">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
    </svg>
  </button>
</div>
