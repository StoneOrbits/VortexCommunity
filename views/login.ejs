<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="dark-theme">
    <%- include('partials/header') %>
    <%- include('partials/nav') %>
    <main>
        <div class="container">
            <% if (error_msg && error_msg.length) { %>
                <div class="alert alert-danger"><%= error_msg %></div>
            <% } %>
            <% if (success_msg && success_msg.length) { %>
                <div class="alert alert-success"><%= success_msg %></div>
            <% } %>
        </div>
        <section class="login-section">
            <form id="loginForm" action="<%= basePath %>/login" method="post">
                <div class="form-group">
                    <label for="username">Username:</label>
                    <input type="text" id="username" name="username" autocomplete="username" required>
                </div>
                <div class="form-group">
                    <label for="password">Password:</label>
                    <input type="password" id="password" name="password" autocomplete="current-password" required>
                </div>
                <div class="form-group">
                    <% if (captchaSiteKey) { %>
                        <button class="g-recaptcha" data-sitekey="<%= captchaSiteKey %>" data-callback='onSubmit' data-action='submit'>Login</button>
                    <% } else { %>
                        <button type="submit">Login</button>
                    <% } %>
                </div>
                <!-- Can't use login with facebook because it requires business verification and I don't run a business, thanks facebook -->
                <!-- <%- include('partials/facebook-login') %> -->
            </form>
        </section>
    </main>
    <%- include('partials/footer') %>
    <%- include('partials/script') %>
    <% if (captchaSiteKey) { %>
    <script src="https://www.google.com/recaptcha/api.js"></script>
    <script>
        function onSubmit(token) {
            document.getElementById("loginForm").submit();
        }
    </script>
    <% } %>
</body>
</html>
