<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="dark-theme">
    <%- include('partials/header') %>
    <%- include('partials/nav') %>
    <main>
        <div class="container">
            <section class="wiki-card">
                <h2 class="section-title">How to Upgrade</h2>
                <p class="section-desc">Find detailed upgrade instructions for your device along with other valuable knowledge on the Vortex Wiki.</p>
                <a href="https://stoneorbits.github.io/VortexEngine/vortex-devices/index.html" target="_blank" class="action-btn">Visit Vortex Wiki</a>
            </section>

            <div class="downloads-grid">
                <% devices.forEach(device => { %>
                    <% if (latestDownloads[device] && latestDownloads[device]['firmware']) { %>
                        <div class="download-card">
                            <div class="download-card-header">
                                <img src="<%= basePath %>/images/<%= device %>-logo-square-64.png" alt="<%= device %>" class="download-card-icon">
                                <h3 class="download-card-title">Vortex <%= device.charAt(0).toUpperCase() + device.slice(1) %></h3>
                            </div>
                            <div class="download-card-body">
                                <p class="download-meta">Released <%= latestDownloads[device]['firmware'].releaseDate %></p>
                                <p class="download-meta">Version <%= latestDownloads[device]['firmware'].version %></p>
                            </div>
                            <div class="download-card-actions">
                                <a href="<%= latestDownloads[device]['firmware'].fileUrl %>" class="action-btn download-btn">Download Firmware</a>
                            </div>
                        </div>
                    <% } %>
                <% }); %>
            </div>

            <!--
            <section class="editor-card">
                <h2 class="section-title">Vortex Desktop Editor</h2>
                <p class="section-desc">The Desktop Editor is a Windows-only application designed to program Vortex devices directly from a computer. It facilitates seamless interaction with all Vortex devices, allowing savefiles to be pushed or pulled to/from vortex devices with ease.</p>
                <div class="editor-screenshots">
                    <img src="<%= basePath %>/images/editor.png" alt="Editor Screenshot" class="editor-screenshot">
                    <img src="<%= basePath %>/images/editor-color-picker.png" alt="Color Picker Screenshot" class="editor-screenshot">
                </div>
                <% if (latestDownloads['desktop'] && latestDownloads['desktop']['editor']) { %>
                    <div class="editor-download">
                        <p class="download-meta">Released <%= latestDownloads['desktop']['editor'].releaseDate %></p>
                        <p class="download-meta">Version <%= latestDownloads['desktop']['editor'].version %></p>
                        <a href="<%= latestDownloads['desktop']['editor'].fileUrl %>" class="action-btn download-btn">Download Editor</a>
                    </div>
                <% } %>
            </section>
            --!>
        </div>
    </main>
    <%- include('partials/footer') %>
    <%- include('partials/script') %>
</body>
</html>
