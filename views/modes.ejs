<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="dark-theme">
    <%- include('partials/header') %>
    <%- include('partials/nav') %>
    <main>
        <% function qsPage(page, search, sort, order) {
            var params = 'page=' + page;
            if (search) params += '&search=' + encodeURIComponent(search);
            if (sort && sort !== 'votes') params += '&sort=' + encodeURIComponent(sort);
            if (order && order !== 'desc') params += '&order=' + encodeURIComponent(order);
            return params;
        } %>
        <form id="search-form" action="<%= basePath %>/modes" method="get">
            <section class="search-bar">
                <div class="search-container">
                    <input type="text" name="search" class="search-input" placeholder="Search..." value="<%= search %>">
                    <button type="submit" class="search-button"><i class="fas fa-search"></i></button>
                </div>
            </section>
        </form>
        <section class="filter-bar">
            <div class="device-filter">
                <% let devices = [
                    { id: 'gloves', name: 'Gloves', img: basePath + '/images/gloves-logo-square-64.png' },
                    { id: 'orbit', name: 'Orbit', img: basePath + '/images/orbit-logo-square-64.png' },
                    { id: 'handle', name: 'Handle', img: basePath + '/images/handle-logo-square-64.png' },
                    { id: 'spark', name: 'Spark', img: basePath + '/images/spark-logo-square-64.png' },
                    { id: 'chromadeck', name: 'Chromadeck', img: basePath + '/images/chromadeck-logo-square-64.png' },
                    { id: 'duo', name: 'Duo', img: basePath + '/images/duo-logo-square-64.png' }
                ]; %>
                <% devices.forEach(function(device) { %>
                    <div class="filter-button">
                        <input type="checkbox" id="<%= device.id %>" name="device" value="<%= device.id %>">
                        <label for="<%= device.id %>">
                            <img src="<%= device.img %>" alt="<%= device.name %> Icon">
                            <%= device.name %>
                        </label>
                    </div>
                <% }); %>
            </div>
        </section>
        <section class="showcase">
            <div class="pagination-bar" id="pagination-bar-top">
                <div class="per-page">
                    <select id="per-page-select">
                        <option value="20">20</option>
                        <option value="40" selected>40</option>
                        <option value="60">60</option>
                        <option value="100">100</option>
                        <option value="0">All</option>
                    </select>
                </div>
                <div id="pagination-container-top"></div>
            </div>
            <div class="modes-list" id="modes-list">
                <% modes.forEach((mode, index) => { %>
                    <%- include('partials/mode-tile', { mode: mode, orderedPatternSets: orderedPatternSetsArray[index] }) %>
                <% }) %>
            </div>
            <div class="pagination-bar" id="pagination-bar-bottom">
                <div class="per-page">
                    <select id="per-page-select-bottom">
                        <option value="20">20</option>
                        <option value="40" selected>40</option>
                        <option value="60">60</option>
                        <option value="100">100</option>
                        <option value="0">All</option>
                    </select>
                </div>
                <div id="pagination-container"></div>
            </div>
        </section>
    </main>
    <%- include('partials/footer') %>
    <%- include('partials/script') %>
</body>
</html>
