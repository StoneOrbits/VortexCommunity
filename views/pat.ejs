<!DOCTYPE html>
<html lang="en">
  <%- include('partials/head') %>
  <body class="dark-theme">
    <%- include('partials/header') %>
    <%- include('partials/nav') %>
    <main>
      <div class="container" id="pat-data-container" data-pat='<%= JSON.stringify(pat) %>'>
        <section class="pat-profile-page">
          <div class="pat-icons">
            <form action="<%= basePath %>/pat/<%= pat.id %>/<%= user && isUpvoted ? 'unvote' : 'upvote' %>" method="post" class="votes-container">
              <button type="submit" class="icon-button">
                <img src="<%= user && isUpvoted ? basePath + '/images/color-upvote-icon.png' : basePath + '/images/bw-upvote-icon.png' %>" alt="Upvote" class="upvote-icon">
              </button>
              <span class="votes-count"><%= pat.votes %></span>
            </form>
            <form action="<%= basePath %>/pat/<%= pat.id %>/<%= user && isFavorited ? 'unfavorite' : 'favorite' %>" method="post" class="favorite-container">
              <button type="submit" class="icon-button">
                <img src="<%= user && isFavorited ? basePath + '/images/color-star-icon.png' : basePath + '/images/bw-star-icon.png' %>" alt="Favorite" class="favorite-icon">
              </button>
            </form>
          </div>
          <h2 class="pat-title"><%= pat.name %></h2>
          <div class="pat-profile-header">
            <p>Uploaded by <%= pat.creator ? `<a href="${basePath}/user/${pat.creator.id}">${pat.creator.username}</a>` : 'Unknown' %> on <%= uploadDate %></p>
          </div>
          <div class="pat-profile-details">
            <p><%= pat.description %></p>
            <% if (user && user.id === pat.createdBy) { %>
            <a href="<%= basePath %>/pat/<%= pat.id %>/edit" class="edit-pat-link">Edit</a>
            <a href="#" class="delete-pat-link" onclick="confirmDelete()">Delete</a>
            <% } %>
            <!-- Confirmation Modal HTML (hidden by default) -->
            <div id="deleteConfirmModal" style="display:none;">
              <p>Are you sure you want to delete this?</p>
              <button onclick="document.getElementById('deleteForm').submit();">Yes, Delete</button>
              <button onclick="document.getElementById('deleteConfirmModal').style.display='none';">Cancel</button>
            </div>
          </div>
          <%- include('partials/pat-profile-lightshow', { pat: pat }) %>
          <div class="pat-profile-actions">
            <% if (user) { %>
            <a href="<%= basePath %>/pat/<%= pat.id %>/download" class="pat-profile-button download-button">Download</a>
            <% } else { %>
            <a href="<%= basePath %>/login" class="pat-profile-button download-button-disabled">Login to Download</a>
            <% } %>
            <a href="<%= lightshowUrl %>" id="openOnLightshow" class="pat-profile-button lightshow-button">lightshow.lol →</a>
          </div>
          <script>
            function confirmDelete() {
              var modal = document.getElementById('deleteConfirmModal');
              modal.style.display = 'block';
            }
          </script>
          <!-- Hidden form for deletion -->
          <form id="deleteForm" action="<%= basePath %>/pat/<%= pat.id %>/delete" method="post" style="display:none;">
          </form>
        </section>
      </div>
    </main>
    <%- include('partials/footer') %>
    <%- include('partials/script') %>
  </body>
</html>
