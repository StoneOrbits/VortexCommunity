<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body class="dark-theme">
    <%- include('partials/header') %>
    <%- include('partials/nav') %>
    <main class="tournaments-page">
        <div class="tournaments-header">
            <h1>Tournaments</h1>
            <div class="tournaments-actions">
                <% if (user) { %>
                    <a href="/tournaments/create" class="btn btn-primary"><i class="fas fa-plus"></i> Create Tournament</a>
                <% } %>
            </div>
        </div>

        <div class="tournaments-filters">
            <a href="/tournaments?filter=active" class="filter-btn <%= currentFilter === 'active' ? 'active' : '' %>">Active</a>
            <a href="/tournaments?filter=completed" class="filter-btn <%= currentFilter === 'completed' ? 'active' : '' %>">Completed</a>
            <a href="/tournaments?filter=archived" class="filter-btn <%= currentFilter === 'archived' ? 'active' : '' %>">Archived</a>
        </div>

        <div class="tournaments-list">
            <% if (tournaments.length === 0) { %>
                <div class="tournaments-empty">
                    <p>No tournaments found.</p>
                    <% if (user) { %>
                        <a href="/tournaments/create" class="btn btn-primary">Create the first tournament</a>
                    <% } %>
                </div>
            <% } else { %>
                <% tournaments.forEach(function(t) { %>
                    <a href="/tournaments/<%= t.id %>" class="tournament-card">
                        <div class="tournament-card-header">
                            <h3><%= t.name %></h3>
                            <span class="tournament-status status-<%= t.status %>"><%= t.status.replace('_', ' ') %></span>
                        </div>
                        <% if (t.description) { %>
                            <p class="tournament-desc"><%= t.description %></p>
                        <% } %>
                        <div class="tournament-card-meta">
                            <span><i class="fas fa-users"></i> <%= registrationCounts[t.id] || 0 %> / <%= t.max_participants %></span>
                            <span><i class="fas fa-tag"></i> <%= t.type %></span>
                            <span><i class="fas fa-user"></i> <%= t.creator ? t.creator.username : 'Unknown' %></span>
                        </div>
                    </a>
                <% }); %>
            <% } %>
        </div>
    </main>
    <%- include('partials/footer') %>
    <%- include('partials/script') %>
</body>
</html>
